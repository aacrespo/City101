{
  "mcpServers": {
    "rhino": {
      "command": "uv",
      "args": ["run", "experiments/rhino mcp server/rhino_router_mcp.py"],
      "env": {
        "RHINO_INSTANCES": "{\"structure\": 9001, \"envelope\": 9002, \"interior\": 9003}",
        "ARCHIBASE_PATH": "H:/Shared drives/City 101/archibase"
      }
    },
    "blender": {
      "command": "uv",
      "args": ["run", "tools/blender/blender_router_mcp.py"],
      "env": {
        "BLENDER_INSTANCES": "{\"main\": 9876, \"second\": 9877, \"third\": 9878}"
      }
    }
  }
}
